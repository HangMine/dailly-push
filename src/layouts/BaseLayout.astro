---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  latestBuild?: {
    status: string;
    builtAt: string;
    commit: string;
  };
}

const {
  title,
  description = 'GitHub 天榜速递，聚合每日热门仓库与中文增长解读。',
  latestBuild,
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const latestBuildLogs = latestBuild
  ? [
      `Latest build: ${latestBuild.status}`,
      `Built at: ${latestBuild.builtAt}`,
      `Commit: ${latestBuild.commit}`,
    ]
  : [];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body>
    <div class="page-shell">
      <div class="ambient ambient-a"></div>
      <div class="ambient ambient-b"></div>

      <header class="site-header">
        <a class="brand" href={baseUrl}>
          <span class="brand-mark">📊</span>
          <span>
            <strong>GitHub 天榜速递</strong>
            <small>SSG Daily Briefing</small>
          </span>
        </a>

        <nav class="site-nav">
          <a href={baseUrl}>最新一期</a>
          <a href={`${baseUrl}archive/`}>历史归档</a>
          <a href="https://github.com/HangMine/dailly-push" target="_blank" rel="noreferrer">
            GitHub
          </a>
        </nav>
      </header>

      <main class="page-main">
        <slot />
      </main>
    </div>

    {
      latestBuildLogs.length > 0 ? (
        <script is:inline>
          {latestBuildLogs.map((line) => `console.log(${JSON.stringify(line)});`).join('\n')}
        </script>
      ) : null
    }
  </body>
</html>
