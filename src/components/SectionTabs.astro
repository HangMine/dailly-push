---
interface Props {
  githubLabel?: string;
  skillsLabel?: string;
  defaultTab?: 'github' | 'skills';
}

const { githubLabel = 'GitHub', skillsLabel = 'Skills', defaultTab = 'github' } = Astro.props;
const githubActive = defaultTab === 'github';
const skillsActive = defaultTab === 'skills';
---

<section class="section-tabs" data-section-tabs>
  <div class="section-tabs__list" role="tablist" aria-label="榜单分类切换">
    <button
      type="button"
      class:list={['section-tabs__tab', githubActive && 'is-active']}
      role="tab"
      aria-selected={githubActive ? 'true' : 'false'}
      aria-controls="panel-github"
      id="tab-github"
      data-tab-trigger="github"
    >
      {githubLabel}
    </button>
    <button
      type="button"
      class:list={['section-tabs__tab', skillsActive && 'is-active']}
      role="tab"
      aria-selected={skillsActive ? 'true' : 'false'}
      aria-controls="panel-skills"
      id="tab-skills"
      data-tab-trigger="skills"
    >
      {skillsLabel}
    </button>
  </div>

  <div class:list={['section-tabs__panel', githubActive && 'is-active']} role="tabpanel" aria-labelledby="tab-github" id="panel-github" data-tab-panel="github" hidden={githubActive ? undefined : true}>
    <slot name="github" />
  </div>

  <div class:list={['section-tabs__panel', skillsActive && 'is-active']} role="tabpanel" aria-labelledby="tab-skills" id="panel-skills" data-tab-panel="skills" hidden={skillsActive ? undefined : true}>
    <slot name="skills" />
  </div>
</section>

<script is:inline>
  const roots = document.querySelectorAll('[data-section-tabs]');
  for (const root of roots) {
    const triggers = Array.from(root.querySelectorAll('[data-tab-trigger]'));
    const panels = Array.from(root.querySelectorAll('[data-tab-panel]'));

    const activate = (key) => {
      for (const trigger of triggers) {
        const active = trigger.getAttribute('data-tab-trigger') === key;
        trigger.classList.toggle('is-active', active);
        trigger.setAttribute('aria-selected', active ? 'true' : 'false');
      }

      for (const panel of panels) {
        const active = panel.getAttribute('data-tab-panel') === key;
        panel.classList.toggle('is-active', active);
        if (active) {
          panel.removeAttribute('hidden');
        } else {
          panel.setAttribute('hidden', '');
        }
      }
    };

    for (const trigger of triggers) {
      trigger.addEventListener('click', () => {
        const key = trigger.getAttribute('data-tab-trigger');
        if (key) activate(key);
      });
    }
  }
</script>
